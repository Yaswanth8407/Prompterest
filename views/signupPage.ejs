<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/signupPage.css">
</head>
<body>
    <div class="body">
        <div class="left">
            <div class="glow-red"></div>
            <div class="grid">
                <div class="g1"><img src="https://i.pinimg.com/736x/41/56/17/4156177df4eca74dbe655544b255374d.jpg" alt="" /></div>
                <div class="g2"><img src="cyber02.jpeg" alt="" /></div>
                <div class="g3"><img src="cyber03.jpeg" alt="" /></div>
            </div>
            <div class="tagline">
                <h2>Discover the<br><span>Impossible.</span></h2>
                <p>Join the AI creator community</p>
            </div>

        </div>
        <div class="right">
         <div class="R">
            <form class="fb" action="/signup" method="post">
                <div class="brand">Prompterest</div>
                <div class="ftitle">Create Your Account</div>
                <div class="fsub">Signup to continue exploring AI prompts</div>

                <div class="fld">
                    <label>Full Name</label>
                    <div class="iw">
                        <span class="ico"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="8" r="4" />
                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
                            </svg></span>
                        <input type="text" placeholder="Your Name" />
                    </div>
                </div>

                <div class="fld">
                    <label>Username</label>
                    <div class="iw">
                        <span class="ico" style="font-size:15px;font-weight:700;font-family:Sora,sans-serif;">@</span>
                        <input type="text" placeholder="prompt_master_69" />
                    </div>
                </div>

                <div class="fld">
                    <label>Email Address</label>
                    <div class="iw">
                        <span class="ico"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2">
                                <rect x="2" y="4" width="20" height="16" rx="2" />
                                <path d="m2 7 10 7 10-7" />
                            </svg></span>
                        <input type="email" placeholder="name@example.com" />
                    </div>
                </div>

                <div class="fld">
                    <label>Password</label>
                    <div class="iw">
                        <span class="ico"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg></span>
                        <input type="password" placeholder="••••••••" />
                    </div>
                </div>

                <button class="btn-main">Create Account</button>

                <div class="divider">or continue with</div>

                                <div class="soc">
                    <button class="sbtn">
                        <svg width="16" height="16" viewBox="0 0 24 24">
                            <path fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                            <path fill="#34A853"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                            <path fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" />
                            <path fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                        </svg>
                        Google
                    </button>
                    <button class="sbtn" type="submit">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z" />
                        </svg>
                        GitHub
                    </button>
                </div>

                <div class="blink">Already have an account? <a href="/showlogin">Login</a></div>
            </form>
        </div>

    </div>




        </div>
    </div>
</body>
</html>
    <script src="/javascripts/signupPage.js"></script>
</body>
</html>