<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prompterest | AI Discovery Feed</title>

    <script>
      (function () {
        let s;
        try {
          s = localStorage.getItem("prest-theme");
        } catch (_) {}
        const d = s
          ? s === "dark"
          : window.matchMedia("(prefers-color-scheme:dark)").matches;
        document.documentElement.classList[d ? "add" : "remove"]("dark");
      })();
    </script>

    <link rel="stylesheet" href="/stylesheets/feedPage.css" />
  </head>
  <body>
    <aside id="sidebar">
      <div class="logo">P</div>

      <nav>
        <a class="nav-icon active" href="#" data-tip="Home">
          <span
            class="material-symbols-outlined"
            style="font-variation-settings: &quot;FILL&quot; 1"
            >home</span
          >
          <span class="nav-label">Home</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Explore">
          <span class="material-symbols-outlined">explore</span>
          <span class="nav-label">Explore</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Create">
          <span class="material-symbols-outlined">add_circle</span>
          <span class="nav-label">Create</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Saved">
          <span class="material-symbols-outlined">bookmark</span>
          <span class="nav-label">Saved</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Notifications">
          <span class="material-symbols-outlined">notifications</span>
          <span class="nav-label">Notifications</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Messages">
          <span class="material-symbols-outlined">chat</span>
          <span class="nav-label">Messages</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Trending">
          <span class="material-symbols-outlined">trending_up</span>
          <span class="nav-label">Trending</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Profile">
          <span class="material-symbols-outlined">person</span>
          <span class="nav-label">Profile</span>
        </a>
      </nav>

      <div class="sidebar-bottom">
        <a class="nav-icon" href="#" data-tip="Settings">
          <span class="material-symbols-outlined">settings</span>
          <span class="nav-label">Settings</span>
        </a>
        <a class="nav-icon" href="#" data-tip="Help">
          <span class="material-symbols-outlined">help_outline</span>
          <span class="nav-label">Help</span>
        </a>
      </div>
    </aside>

    <header id="header" class="header-in">
      <div class="header-left">
        <h1 class="header-logo">Prompterest</h1>

        <div class="search-wrap">
          <span class="material-symbols-outlined search-icon">search</span>
          <input
            class="search-input"
            type="text"
            placeholder="Search AI prompts, artists, styles…"
            aria-label="Search"
          />
        </div>
      </div>

      <div class="header-right">
        <button
          class="toggle-track"
          onclick="toggleTheme()"
          aria-label="Toggle dark/light mode"
        >
          <span
            class="toggle-star"
            style="width: 3px; height: 3px; top: 5px; left: 13px"
          ></span>
          <span
            class="toggle-star"
            style="width: 2px; height: 2px; top: 15px; left: 20px"
          ></span>
          <span
            class="toggle-star"
            style="width: 2px; height: 2px; top: 7px; left: 32px"
          ></span>
          <div class="toggle-knob">
            <span class="material-symbols-outlined" id="toggle-icon"
              >dark_mode</span
            >
          </div>
        </button>

        <button class="icon-btn" aria-label="Notifications">
          <span class="material-symbols-outlined">notifications</span>
        </button>
        <button class="icon-btn" aria-label="AI Tools">
          <span class="material-symbols-outlined">psychology</span>
        </button>

        <img
          class="avatar"
          src="https://media.licdn.com/dms/image/v2/D4D03AQEgCuuhRC7DvA/profile-displayphoto-scale_400_400/B4DZ2ve7N1GcAg-/0/1776765615153?e=1780531200&v=beta&t=CG1B6CKOSs7dxQ5FiyH15hI_R-atnXYlUK3upFppL-0"
          alt="User avatar"
        />
      </div>
    </header>
