    <header id="header" class="header-in">
      <div class="header-left">
        <h1 class="header-logo">Prompterest</h1>

        <div class="search-wrap">
          <span class="material-symbols-outlined search-icon">search</span>
          <input
            class="search-input"
            type="text"
            placeholder="Search AI prompts, artists, styles…"
            aria-label="Search"
          />
        </div>
      </div>

      <div class="header-right">
        <button
          class="toggle-track"
          onclick="toggleTheme()"
          aria-label="Toggle dark/light mode"
        >
          <span
            class="toggle-star"
            style="width: 3px; height: 3px; top: 5px; left: 13px"
          ></span>
          <span
            class="toggle-star"
            style="width: 2px; height: 2px; top: 15px; left: 20px"
          ></span>
          <span
            class="toggle-star"
            style="width: 2px; height: 2px; top: 7px; left: 32px"
          ></span>
          <div class="toggle-knob">
            <span class="material-symbols-outlined" id="toggle-icon"
              >dark_mode</span
            >
          </div>
        </button>

        <button class="icon-btn" aria-label="Notifications">
          <span class="material-symbols-outlined">notifications</span>
        </button>
        <button class="icon-btn" aria-label="AI Tools">
          <span class="material-symbols-outlined">psychology</span>
        </button>

        <img
          class="avatar"
          src="https://media.licdn.com/dms/image/v2/D4D03AQEgCuuhRC7DvA/profile-displayphoto-scale_400_400/B4DZ2ve7N1GcAg-/0/1776765615153?e=1780531200&v=beta&t=CG1B6CKOSs7dxQ5FiyH15hI_R-atnXYlUK3upFppL-0"
