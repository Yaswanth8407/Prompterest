<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prompterest | AI Discovery Feed</title>

    <script>
      (function () {
        let s;
        try {
          s = localStorage.getItem("prest-theme");
        } catch (_) {}
        const d = s
          ? s === "dark"
          : window.matchMedia("(prefers-color-scheme:dark)").matches;
        document.documentElement.classList[d ? "add" : "remove"]("dark");
      })();
    </script>

    <link rel="stylesheet" href="/stylesheets/feedPage.css" />
  </head>
